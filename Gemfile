source "https://rubygems.org"

# Minimal-Mistakes is a Jekyll theme that simplifies the process of creating a responsive,
# elegant, and clean website with Jekyll.
gem "minimal-mistakes-jekyll"

group :jekyll_plugins do
  # GitHub Pages is a Jekyll plugin that helps to build GitHub Pages sites.
  # It bundles other useful plugins that are supported by GitHub Pages.
  gem "github-pages"
end